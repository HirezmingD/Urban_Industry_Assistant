# ============================================================
# Urban_Industry_Assistant 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# --- DeepSeek LLM ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# --- 天地图 API ---
TIANDITU_API_KEY=your_tianditu_api_key_here
# 瓦片 URL 模板（默认 img_w 服务，WGS84 球面墨卡托）
# TIANDITU_TILE_URL_TEMPLATE=http://t{s}.tianditu.gov.cn/img_w/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=img&STYLE=default&TILEMATRIXSET=w&FORMAT=tiles&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}&tk={key}

# --- EvoMap Hub ---
EVOMAP_HUB_URL=https://evomap.ai
# EVOMAP_NODE_ID=   ← 或放入 ~/.evomap/node_id
# EVOMAP_NODE_SECRET=   ← 或放入 ~/.evomap/node_secret

# --- 数据库 ---
# DATABASE_PATH=db/uia.db

# --- 数据目录 ---
# DATA_DIR=data/
